    data = api_call(f"/v1/etf/{coin}")
    
    print(f"\n📈 {coin} ETF 数据")
    print("=" * 50)
    
    d = data.get("data", {})
    overview = d.get("overview", {})
    
    print(f"\n💰 概览:")
    print(f"   总净流入: ${format_number(float(overview.get('total_net_inflow', 0)))}")
    print(f"   日净流入: {overview.get('daily_net_inflow', 'N/A')}")
    print(f"   日交易量: ${format_number(float(overview.get('daily_trading_volume', 0)))}")
    print(f"   总资产: ${format_number(float(overview.get('total_net_assets', 0)))}")
    print(f"   持仓机构: {d.get('holdings_count', 0)} 家")
    
    print(f"\n🏆 主要 ETF:")
    for holding in d.get("top_holdings", [])[:5]:
        ticker = holding.get("ticker", "N/A")
        name = holding.get("name", "N/A")
        aum = float(holding.get("aum", 0))
        change = holding.get("price_change_percent", "N/A")
        
        print(f"   {ticker.upper():8s} {name[:25]:25s} AUM: ${format_number(aum)} ({change}%)")

def main():
    parser = argparse.ArgumentParser(description="DogEye Data Skill")
    subparsers = parser.add_subparsers(dest="command", help="命令")
    
    # block-trades
    p1 = subparsers.add_parser("block-trades", help="查询大单交易")
    p1.add_argument("coin", help="币种 (BTC, ETH, etc.)")
    
    # fund-flow
    p2 = subparsers.add_parser("fund-flow", help="查询资金流")
    p2.add_argument("coin", help="币种")
    p2.add_argument("--period", default="1D", help="周期 (5M, 1H, 1D)")
    
    # long-short
    p3 = subparsers.add_parser("long-short", help="查询多空比")
    p3.add_argument("coin", help="币种")
    
    # funding
    p4 = subparsers.add_parser("funding", help="查询资金费率")
    p4.add_argument("coin", help="币种")
    
    # fear-greed
    p5 = subparsers.add_parser("fear-greed", help="查询恐惧贪婪指数")
    
    # quota
    p6 = subparsers.add_parser("quota", help="查询账户配额")
    
    # rsi-heatmap (新增)
    p7 = subparsers.add_parser("rsi-heatmap", help="查询RSI热力图")
    p7.add_argument("--coins", default="BTC,ETH,SOL", help="币种列表，逗号分隔")
    p7.add_argument("--timeframe", default="1H", help="周期 (15M, 1H, 4H, 1D)")
    
    # market-depth (新增)
    p8 = subparsers.add_parser("market-depth", help="查询市场深度")
    p8.add_argument("coin", help="币种")
    
    # grayscale (新增)
    p9 = subparsers.add_parser("grayscale", help="查询灰度持仓")
    p9.add_argument("coin", help="币种 (BTC, ETH)")
    
    # etf (新增)
    p10 = subparsers.add_parser("etf", help="查询ETF数据")
    p10.add_argument("coin", help="币种 (btc, eth)")
    
    args = parser.parse_args()
    
    if args.command == "block-trades":
        cmd_block_trades(args.coin)
    elif args.command == "fund-flow":
        cmd_fund_flow(args.coin, args.period)
    elif args.command == "long-short":
        cmd_long_short(args.coin)
    elif args.command == "funding":
        cmd_funding(args.coin)
    elif args.command == "fear-greed":
        cmd_fear_greed()
    elif args.command == "quota":
        cmd_quota()
    elif args.command == "rsi-heatmap":
        cmd_rsi_heatmap(args.coins, args.timeframe)
    elif args.command == "market-depth":
        cmd_market_depth(args.coin)
    elif args.command == "grayscale":
        cmd_grayscale(args.coin)
    elif args.command == "etf":
        cmd_etf(args.coin)
    else:
        parser.print_help()

if __name__ == "__main__":
    main()
