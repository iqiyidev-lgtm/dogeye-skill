def cmd_rsi_heatmap(coins, timeframe):
    """RSI热力图"""
    params = {"coins": coins, "timeframe": timeframe}
    data = api_call("/v1/rsi-heatmap", params)
    
    print(f"\n📊 RSI 热力图 ({timeframe})")
    print("=" * 50)
    
    rsi_data = data.get("data", {}).get("ris_data", {}).get("data", [])
    
    for item in rsi_data:
        coin = item.get("coin_type", "N/A")
        rsi_first = float(item.get("first_data", 0))
        rsi_last = float(item.get("last_data", 0))
        
        # 根据 RSI 值显示不同颜色
        if rsi_last >= 70:
            status = "🔴 超买"
        elif rsi_last <= 30:
            status = "🟢 超卖"
        else:
            status = "⚪ 中性"
        
        trend = "📈" if rsi_last > rsi_first else "📉"
        print(f"  {coin:6s} RSI: {rsi_last:.2f} {trend} {status}")

def cmd_market_depth(coin):
    """市场深度"""
    data = api_call(f"/v1/market-depth/{coin}")
    
    print(f"\n📈 {coin} 市场深度 (前100档)")
    print("=" * 50)
    
    exchanges = data.get("data", {}).get("exchanges", {})
    
    for ex_name, ex_data in exchanges.items():
        if "error" in ex_data:
            print(f"\n🏢 {ex_name.upper()}: 数据获取失败")
            continue
        
        bids = ex_data.get("bids_100", 0)
        asks = ex_data.get("asks_100", 0)
        ratio = ex_data.get("bid_ask_ratio", 0)
        
        # 判断买卖力量
        if ratio > 1.5:
            sentiment = "🟢 买盘强势"
        elif ratio > 1.1:
            sentiment = "🟡 买盘占优"
        elif ratio < 0.7:
            sentiment = "🔴 卖盘强势"
        elif ratio < 0.9:
            sentiment = "🟠 卖盘占优"
        else:
            sentiment = "⚪ 相对平衡"
        
        print(f"\n🏢 {ex_name.upper()}")
        print(f"  买盘: {format_number(bids)} | 卖盘: {format_number(asks)}")
        print(f"  买卖比: {ratio:.2f} {sentiment}")

def cmd_grayscale(coin):
    """灰度持仓"""
    data = api_call(f"/v1/grayscale/{coin}")
    
    print(f"\n🏛️  {coin} 灰度持仓")
    print("=" * 50)
    
    d = data.get("data", {})
    hold = d.get("latest_hold", 0)
    change_1d = d.get("change_1d", 0)
    change_7d = d.get("change_7d", 0)
    
    print(f"\n📊 最新持仓: {hold:,.2f} {coin}")
    
    # 1日变化
    if change_1d < 0:
        print(f"   1日变化: 🔴 {change_1d:,.2f} (减持)")
    else:
        print(f"   1日变化: 🟢 +{change_1d:,.2f} (增持)")
    
    # 7日变化
    if change_7d < 0:
        print(f"   7日变化: 🔴 {change_7d:,.2f} (减持)")
    else:
        print(f"   7日变化: 🟢 +{change_7d:,.2f} (增持)")
    
    print(f"\n📅 更新时间: {d.get('update_time', 'N/A')}")

