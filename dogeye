#!/usr/bin/env python3
"""
DogEye Data Skill CLI
调用 api.leilei.uk 获取实时市场数据
"""

import os
import sys
import json
import argparse
import requests
from datetime import datetime

API_BASE = "https://api.leilei.uk"

def get_user_id():
    """获取用户ID"""
    return os.getenv("DOGEYE_USER_ID", f"oc_{os.getpid()}")

def api_call(endpoint, params=None):
    """调用 API"""
    if params is None:
        params = {}
    
    user_id = get_user_id()
    params["user_id"] = user_id
    
    url = f"{API_BASE}{endpoint}"
    
    try:
        resp = requests.get(url, params=params, timeout=15)
        resp.raise_for_status()
        return resp.json()
    except requests.exceptions.RequestException as e:
        print(f"❌ API 请求失败: {e}")
        sys.exit(1)

def format_number(n):
    """格式化数字"""
    n = float(n)
    if abs(n) >= 1e9:
        return f"{n/1e9:.2f}B"
    elif abs(n) >= 1e6:
        return f"{n/1e6:.2f}M"
    elif abs(n) >= 1e3:
        return f"{n/1e3:.1f}K"
    return f"{n:.2f}"

def cmd_block_trades(coin):
    """大单交易"""
    data = api_call(f"/v1/block-trades/{coin}")
    
    print(f"\n📊 {coin} 大单交易")
    print("=" * 50)
    
    if "contract" in data.get("data", {}):
        c = data["data"]["contract"]
        print(f"\n🔄 合约市场:")
        print(f"  1H 买入: ${format_number(c.get('buy_1h', 0))}")
        print(f"  1H 卖出: ${format_number(c.get('sell_1h', 0))}")
        net = c.get('net_1h', 0)
        emoji = "🟢" if net > 0 else "🔴"
        print(f"  1H 净流: {emoji} ${format_number(net)}")
        print(f"  24H 总成交: ${format_number(c.get('total_24h', 0))}")
    
    if "spot" in data.get("data", {}):
        s = data["data"]["spot"]
        print(f"\n💰 现货市场:")
        print(f"  1H 买入: ${format_number(s.get('buy_1h', 0))}")
        print(f"  1H 卖出: ${format_number(s.get('sell_1h', 0))}")
        net = s.get('net_1h', 0)
        emoji = "🟢" if net > 0 else "🔴"
        print(f"  1H 净流: {emoji} ${format_number(net)}")
    
    print(f"\n💾 缓存: {'是' if data.get('cached') else '否'}")

def cmd_fund_flow(coin, period="1D"):
    """资金流"""
    data = api_call(f"/v1/fund-flow/{coin}", {"period": period})
    
    print(f"\n💸 {coin} 资金流 ({period})")
    print("=" * 50)
    
    spot = data.get("data", {}).get("spot", {})
    contract = data.get("data", {}).get("contract", {})
    
    if spot.get("list"):
        latest = spot["list"][0]
        net = float(latest.get("net_flow", 0))
        emoji = "🟢 流入" if net > 0 else "🔴 流出"
        print(f"\n📈 现货最新 ({latest.get('time_interval')}):")
        print(f"  流入: ${format_number(latest.get('inflow', 0))}")
        print(f"  流出: ${format_number(latest.get('outflow', 0))}")
        print(f"  净流: {emoji} ${format_number(net)}")
    
    if contract.get("list"):
        latest = contract["list"][0]
        net = float(latest.get("net_flow", 0))
        emoji = "🟢 流入" if net > 0 else "🔴 流出"
        print(f"\n📉 合约最新 ({latest.get('time_interval')}):")
        print(f"  流入: ${format_number(latest.get('inflow', 0))}")
        print(f"  流出: ${format_number(latest.get('outflow', 0))}")
        print(f"  净流: {emoji} ${format_number(net)}")

def cmd_long_short(coin):
    """多空比"""
    data = api_call(f"/v1/long-short/{coin}")
    
    print(f"\n⚖️  {coin} 多空比")
    print("=" * 50)
    
    items = data.get("data", [])
    
    # 找全网数据
    all_data = None
    for item in items:
        if item.get("exchange") == "ALL_BEFORE":
            all_data = item
            break
    
    if all_data:
        long_r = float(all_data.get("long_ratio", 0))
        short_r = float(all_data.get("short_ratio", 0))
        ratio = all_data.get("long_short_ratio", 1.0)
        
        print(f"\n🌐 全网多空比:")
        print(f"  多头: {long_r:.1f}%")
        print(f"  空头: {short_r:.1f}%")
        print(f"  比值: {ratio:.2f}")
        print(f"  情绪: {all_data.get('sentiment', 'N/A')}")
    
    # 显示主要交易所
    print(f"\n🏢 主要交易所:")
    for item in items[:5]:
        ex = item.get("exchange", "N/A")
        if ex == "ALL_BEFORE":
            continue
        long_r = float(item.get("long_ratio", 0))
        short_r = float(item.get("short_ratio", 0))
        print(f"  {ex:12s} 多{long_r:.1f}% / 空{short_r:.1f}%")

def cmd_funding(coin):
    """资金费率"""
    data = api_call(f"/v1/funding-rate/{coin}")
    
    print(f"\n💰 {coin} 资金费率")
    print("=" * 50)
    
    rates = data.get("data", {}).get("rates", {}).get("data", [])
    
    print(f"\n📊 主要交易所费率:")
    for item in rates[:10]:
        ex = item.get("exchange", "N/A")
        contract = item.get("contract_type", "N/A")
        rate = item.get("funding_rate", "N/A")
        signal = item.get("funding_signal", "N/A")
        
        # 简化显示
        if "USDT" in contract:
            emoji = "🟢" if "long" in signal else "🔴" if "short" in signal else "⚪"
            print(f"  {emoji} {ex:12s} {rate:10s} ({signal})")

def cmd_fear_greed():
    """恐惧贪婪指数"""
    data = api_call("/v1/fear-greed")
    
    print(f"\n😨 恐惧贪婪指数")
    print("=" * 50)
    
    d = data.get("data", {})
    value = d.get("value", 0)
    classification = d.get("classification", "N/A")
    
    # 根据值显示不同表情
    if value <= 20:
        emoji = "😱"
    elif value <= 40:
        emoji = "😰"
    elif value <= 60:
        emoji = "😐"
    elif value <= 80:
        emoji = "😊"
    else:
        emoji = "🤩"
    
    print(f"\n{emoji} 当前指数: {value}")
    print(f"   状态: {classification}")
    print(f"\n💡 解读:")
    if value <= 20:
        print("   市场极度恐慌，可能是买入机会")
    elif value >= 80:
        print("   市场极度贪婪，注意风险")
    else:
        print("   市场情绪中性")

